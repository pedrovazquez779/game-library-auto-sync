# Copy to .env and fill in your values: cp .env.example .env
# Steam Web API key: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=
# Your 64-bit SteamID (steamID64): 17-digit number starting with 7656119...
# Find it in your profile URL (/profiles/7656119...) or paste your profile
# into steamid.io. Requires "Game details" set to Public in Steam privacy.
STEAM_ID64=
# Notion integration token: https://www.notion.so/my-integrations
NOTION_TOKEN=
# Notion database ID (share the DB with your integration).
# It's the ID, NOT the database title. Open the DB as a full page and copy the
# 32-char hex string from the URL, before the "?v=":
#   https://www.notion.so/workspace/8a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d?v=...
#                                   ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ this part
# Take it from the database itself (not a page/view inside it).
NOTION_DB_ID=
# Optional: hours between syncs (default 6)
SYNC_INTERVAL_HOURS=6
